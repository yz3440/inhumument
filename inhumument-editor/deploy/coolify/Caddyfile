# Mirrors inhumument-editor/public/_headers (Cloudflare Pages) for self-hosting.
# Plain :80 — the reverse proxy in front (Coolify's Traefik) terminates TLS.
:80

root * /srv
encode gzip

# HTML entries must revalidate — stale cached HTML would reference purged
# content-hashed /assets/* chunks after a redeploy. Extensionless paths are
# included because Cloudflare Pages canonicalizes /docs.html -> /docs, so
# shared URLs may arrive without the extension (try_files maps them back).
@html path / /index.html /preview.html /docs.html /about.html /index /preview /docs /about
header @html Cache-Control "no-cache"
try_files {path} {path}.html

header /db/* Access-Control-Allow-Origin "*"
header /pages_normalized/* {
	Access-Control-Allow-Origin "*"
	Cache-Control "public, max-age=31536000, immutable"
}
header /db/pages/* Cache-Control "public, max-age=86400"
header /db/catalog.json Cache-Control "public, max-age=3600"
header /db/search-index.json Cache-Control "public, max-age=3600"
header /assets/* Cache-Control "public, max-age=31536000, immutable"

file_server
